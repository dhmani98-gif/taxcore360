# Lemon Squeezy Webhook Environment Variables
# Copy this to .env and fill in your actual values

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Service Role Key (keep this secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Lemon Squeezy Webhook Secret (from Lemon Squeezy dashboard)
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret-here
